{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "name": "Тест Юзер", "phone": "+70000000099", "password": "secret123"},
      "expectedStatus": 200,
      "expectedBody": {"name": "Тест Юзер"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login existing user",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "phone": "+70000000099", "password": "secret123"},
      "expectedStatus": 200,
      "expectedBody": {"name": "Тест Юзер"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "phone": "+70000000099", "password": "wrong"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Неверный номер или пароль"},
      "bodyMatcher": "partial"
    }
  ]
}
